# ==============================================
# MUNDO ROBERTH AGENT OS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ==============================================

# ---- IA / LLM ----
# Escolha um provedor e preencha a chave correspondente
OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...

# Provedor padrão: openai | google | anthropic
AI_PROVIDER=google
AI_MODEL=gemini-2.0-flash-exp

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=seu_bot_token_aqui
TELEGRAM_WEBHOOK_URL=https://seu-dominio.com/api/telegram/webhook
# Seu Telegram ID (para restringir acesso)
TELEGRAM_ADMIN_USER_ID=seu_id_aqui

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://hooygjhbqfqtfqqfccxh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
SUPABASE_URL=https://hooygjhbqfqtfqqfccxh.supabase.co
# Preencha a senha do Postgres:
DATABASE_URL=postgresql://postgres:SUA_SENHA_AQUI@db.hooygjhbqfqtfqqfccxh.supabase.co:5432/postgres

# ---- GitHub ----
GITHUB_TOKEN=seu_github_token_aqui
GITHUB_OWNER=naninneagent-max2
GITHUB_REPO=Naninne-Agent-

# ---- Notion ----
NOTION_API_TOKEN=secret_...
NOTION_WORKSPACE_ID=...

# ---- Vercel ----
VERCEL_TOKEN=...
VERCEL_TEAM_ID=...
VERCEL_PROJECT_ID=...

# ---- App ----
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Redis (para filas locais) ----
REDIS_URL=redis://localhost:6379

# ---- Segurança ----
# JWT secret para sessões do dashboard
JWT_SECRET=gere-um-secret-aqui-com-32-chars-min
